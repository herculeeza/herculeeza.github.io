# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC URLs
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key
MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# Gas reporting
REPORT_GAS=true

# Contract deployment parameters
NFT_NAME=Harburger NFT
NFT_SYMBOL=HBRG
# Annual tax percentage (deploy script converts to per-second rate with RATE_PRECISION=1e18)
ANNUAL_TAX_PERCENT=10
# Or provide a pre-computed per-second rate directly (overrides ANNUAL_TAX_PERCENT):
# TAX_RATE=3170979198
TAX_RECEIVER=0x1234567890123456789012345678901234567890
# Initial price in wei (default: deploy script uses ethers.parseEther("0.001"))
# INITIAL_PRICE=1000000000000000

# DeFi Protocol Addresses (Optional - for yield strategies)
# Sepolia testnet addresses:
AAVE_POOL_ADDRESSES_PROVIDER=0x0000000000000000000000000000000000000000
WETH_ADDRESS=0x0000000000000000000000000000000000000000
AWETH_ADDRESS=0x0000000000000000000000000000000000000000
COMPOUND_COMET=0x0000000000000000000000000000000000000000