# Deployed Harburger contract address
VITE_CONTRACT_ADDRESS=

# Expected chain ID (optional, validates wallet is on the right network)
# 1 = mainnet, 11155111 = sepolia, 1337 = localhost
# VITE_CHAIN_ID=11155111

